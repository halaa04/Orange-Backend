@model List<StudentsCRUD.Models.Student>

<h2>Students List</h2>
<a href="/Students/Create">+ Add New Student</a>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Age</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Id</td>
                <td>@s.Name</td>
                <td>@s.Age</td>
                <td>
                    <a href="/Students/Edit/@s.Id">Edit</a> |
                    <a href="/Students/Delete/@s.Id"
                       onclick="return confirm('Delete this student?')">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>